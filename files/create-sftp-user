#!/usr/bin/env bash
# create-sftp-user — provision a single chrooted SFTP user.
#
# Argument is one user spec:
#   user:pass[:e][:uid[:gid[:dir1[,dir2]...]]]
#
#   user   required username
#   pass   password; leave empty to disable password login (key-only auth)
#   :e     marks the password field as already-encrypted (passed to `chpasswd -e`)
#   uid    optional numeric user id
#   gid    optional numeric group id (a matching group is created if absent)
#   dirN   comma-separated directories created (writable) under the user's home
#
# This mirrors the user-definition format of atmoz/sftp.
set -Eeo pipefail

log() { echo "[create-sftp-user] $*" >&2; }
die() { log "ERROR: $*"; exit 1; }
trap 'die "failed at line $LINENO: $BASH_COMMAND"' ERR

# Validation patterns. Password and dir fields simply cannot contain ':'.
reUser='[A-Za-z0-9._][A-Za-z0-9._-]{0,31}'
rePass='[^:]{0,255}'
reUid='[[:digit:]]*'
reGid='[[:digit:]]*'
reDir='[^:]*'

spec="$1"
[ -z "$spec" ] && die "no user spec given"

if [[ "$spec" =~ ^($reUser)(:$rePass)(:e)?(:$reUid)?(:$reGid)?(:$reDir)?$ ]]; then
    user="${BASH_REMATCH[1]}"
    pass="${BASH_REMATCH[2]:1}"   # strip the leading ':' the group captured
    if [ "${BASH_REMATCH[3]}" = ":e" ]; then
        chpasswdOptions="-e"
        uid="${BASH_REMATCH[4]:1}"
        gid="${BASH_REMATCH[5]:1}"
        dir="${BASH_REMATCH[6]:1}"
    else
        chpasswdOptions=""
        uid="${BASH_REMATCH[3]:1}"
        gid="${BASH_REMATCH[4]:1}"
        dir="${BASH_REMATCH[5]:1}"
    fi
else
    die "invalid user spec '$spec' (expected user:pass[:e][:uid[:gid[:dir1,dir2...]]])"
fi

getent passwd "$user" >/dev/null && die "user '$user' already exists"

# Build useradd options.
useraddOptions=(--no-user-group)
[ -n "$uid" ] && useraddOptions+=(--non-unique --uid "$uid")
if [ -n "$gid" ]; then
    getent group "$gid" >/dev/null || groupadd --gid "$gid" "group_$gid"
    useraddOptions+=(--gid "$gid")
fi

useradd "${useraddOptions[@]}" "$user"

# The chroot target (the user's home) must be owned by root and not
# group/world-writable, so the user only writes inside mounted volumes or the
# subdirectories created below.
mkdir -p "/home/$user"
chown root:root "/home/$user"
chmod 755 "/home/$user"

# Password handling.
if [ -n "$pass" ]; then
    echo "$user:$pass" | chpasswd $chpasswdOptions
else
    # No password: disable password auth but keep the account usable via keys.
    usermod -p '*' "$user"
fi
unset pass

# Aggregate any mounted public keys into authorized_keys.
if [ -d "/home/$user/.ssh/keys" ]; then
    mkdir -p "/home/$user/.ssh"
    cat "/home/$user/.ssh/keys/"* >> "/home/$user/.ssh/authorized_keys"
    chown -R "$user" "/home/$user/.ssh"
    chmod 700 "/home/$user/.ssh"
    chmod 600 "/home/$user/.ssh/authorized_keys"
fi

# Create writable subdirectories inside the chroot.
if [ -n "$dir" ]; then
    IFS=',' read -ra dirs <<< "$dir"
    for d in "${dirs[@]}"; do
        mkdir -p "/home/$user/$d"
        chown -R "$user":users "/home/$user/$d"
    done
fi

log "created user '$user'"
